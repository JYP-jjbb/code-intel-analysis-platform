<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mickey.onlineordering.onlineorderingserver.mapper.DishMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.mickey.onlineordering.onlineorderingserver.entity.Dish">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="price" property="price"/>
        <result column="category_id" property="categoryId"/>
        <result column="description" property="description"/>
        <result column="image_url" property="imageUrl"/>
        <result column="stock" property="stock"/>
        <result column="sales" property="sales"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, name, price, category_id, description, image_url, stock, sales, status, create_time, update_time
    </sql>
    
    <!-- 查询条件 -->
    <sql id="Query_Condition">
        <where>
            <if test="keyword != null and keyword != ''">
                AND name LIKE CONCAT('%', #{keyword}, '%')
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </sql>
    
    <!-- 根据ID查询菜品 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tb_dish
        WHERE id = #{id}
    </select>
    
    <!-- 根据条件查询菜品列表 -->
    <select id="selectByCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tb_dish
        <include refid="Query_Condition"/>
        <if test="orderBy != null and orderBy != ''">
            ORDER BY ${orderBy}
        </if>
        <if test="orderBy == null or orderBy == ''">
            ORDER BY id DESC
        </if>
        <if test="pageNum != null and pageSize != null">
            OFFSET #{pageNum} ROWS FETCH NEXT #{pageSize} ROWS ONLY
        </if>
    </select>
    
    <!-- 根据条件统计菜品数量 -->
    <select id="countByCondition" resultType="long">
        SELECT COUNT(*)
        FROM tb_dish
        <include refid="Query_Condition"/>
    </select>
    
    <!-- 插入菜品 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_dish (name, price, category_id, description, image_url, stock, sales, status, create_time, update_time)
        VALUES (#{name}, #{price}, #{categoryId}, #{description}, #{imageUrl}, #{stock}, #{sales}, #{status}, #{createTime}, #{updateTime})
    </insert>
    
    <!-- 更新菜品 -->
    <update id="update">
        UPDATE tb_dish
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="price != null">price = #{price},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="description != null">description = #{description},</if>
            <if test="imageUrl != null">image_url = #{imageUrl},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="status != null">status = #{status},</if>
            update_time = #{updateTime}
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 删除菜品 -->
    <delete id="deleteById">
        DELETE FROM tb_dish WHERE id = #{id}
    </delete>
    
    <!-- 更新销量 -->
    <update id="updateSales">
        UPDATE tb_dish
        SET sales = sales + #{quantity}
        WHERE id = #{id}
    </update>
    
    <!-- 更新库存 -->
    <update id="updateStock">
        UPDATE tb_dish
        SET stock = stock - #{quantity}
        WHERE id = #{id}
    </update>
    
</mapper>












