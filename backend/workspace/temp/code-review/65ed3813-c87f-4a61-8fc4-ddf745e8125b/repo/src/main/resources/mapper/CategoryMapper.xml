<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mickey.onlineordering.onlineorderingserver.mapper.CategoryMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.mickey.onlineordering.onlineorderingserver.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="sort" property="sort"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, name, sort, description, status, create_time, update_time
    </sql>
    
    <!-- 根据ID查询分类 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tb_category
        WHERE id = #{id}
    </select>
    
    <!-- 查询所有分类 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tb_category
        ORDER BY sort ASC, id ASC
    </select>
    
    <!-- 查询启用的分类 -->
    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM tb_category
        WHERE status = #{status}
        ORDER BY sort ASC, id ASC
    </select>
    
    <!-- 插入分类 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_category (name, sort, description, status, create_time, update_time)
        VALUES (#{name}, #{sort}, #{description}, #{status}, #{createTime}, #{updateTime})
    </insert>
    
    <!-- 更新分类 -->
    <update id="update">
        UPDATE tb_category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null">status = #{status},</if>
            update_time = #{updateTime}
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 删除分类 -->
    <delete id="deleteById">
        DELETE FROM tb_category WHERE id = #{id}
    </delete>
    
</mapper>












